{
	"manifest_version": 2,
	"name": "Browser Vim Navigator",
	"version": "0.0.0",

	"description": "A simple vim like navigator for browser",

	"icons": {
		"48": "icons/logo-48.png"
	},

	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content-scripts/vim.js"]
		}
	],

	"background": {
		"scripts": ["background/index.js"],
		"type": "module"
	},

	"permissions": ["activeTab", "storage", "scripting"]
}
